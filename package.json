{
  "name": "chat-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Chat agent with tool calling",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm --filter chat-agent-backend test",
    "lint": "biome check . --diagnostic-level=error",
    "lint:fix": "biome check . --write --diagnostic-level=error",
    "db:push": "pnpm --filter chat-agent-backend db:push",
    "db:generate": "pnpm --filter chat-agent-backend db:generate",
    "db:migrate": "pnpm --filter chat-agent-backend db:migrate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
